{
    "testEnvironment": "node",
    "bail": 1,
    "verbose": true,
    "moduleNameMapper": {
        "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "extensionsToTreatAsEsm": [
        ".ts",
        ".mts",
        ".tsx"
    ],
    "testPathIgnorePatterns": [
        "/node_modules/",
        "/templates/"
    ],
    "testMatch": [
        "**/__tests__/**/mjs?(x)",
        "**/test/?(*.)+(spec|test).mjs?(x)",
        "**/__tests__/**/ts?(x)",
        "**/test/?(*.)+(spec|test).ts?(x)"
    ],
    "transform": {
        "^.+.tsx?$": [
            "ts-jest",
            {
                "useESM": true
            }
        ]
    }
}
